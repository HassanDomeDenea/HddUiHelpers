{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "HddUiHelpers/*": ["./*"]
    },
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["vite/client"]
  }
}
